{
  "name": "todo-today-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go --lan",
    "start:dev-client": "APP_VARIANT=dev expo start --dev-client",
    "start:tunnel": "expo start --go --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "ios:device": "APP_VARIANT=dev expo run:ios --device",
    "ios:device:dev": "APP_VARIANT=dev expo run:ios --device",
    "ios:device:release": "APP_VARIANT=release expo run:ios --device --configuration Release",
    "prebuild:ios": "APP_VARIANT=release expo prebuild --platform ios",
    "prebuild:ios:dev": "APP_VARIANT=dev expo prebuild --platform ios",
    "prebuild:ios:clean": "APP_VARIANT=release expo prebuild --platform ios --clean",
    "prebuild:ios:clean:dev": "APP_VARIANT=dev expo prebuild --platform ios --clean",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo"
  }
}
